<div class="glass-panel">
  <h2>Blocked Fulfillment Dates</h2>
  <p class="subtitle">Manage days where delivery and pickup are unavailable.</p>

  <div id="alerts"></div>

  <div style="display: flex; gap: 1rem; align-items: flex-end; margin-bottom: 2rem;">
    <div class="input-group" style="margin-bottom: 0; flex-grow: 1;">
      <label for="newDate">Add a Date</label>
      <input type="date" id="newDate">
    </div>
    <button id="addDateBtn" class="btn btn-primary"
      style="padding: 0.75rem 2rem; box-shadow: 0 4px 12px rgba(88, 166, 255, 0.2);">Add</button>
  </div>

  <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--glass-border); padding-bottom: 1rem;">
    <h3 style="font-size: 1.1rem; font-weight: 500;">Currently Blocked Dates</h3>
    <button id="saveDatesBtn" class="btn btn-primary" style="display: none;">Save to Shopify</button>
  </div>

  <ul id="datesContainer" class="date-list">
    <!-- Dates will be injected here via JS -->
  </ul>
</div>

<template id="dateItemTemplate">
  <li class="date-item">
    <span class="date-text"></span>
    <button class="remove-btn">&times;</button>
  </li>
</template>

<script>
  let blockedDates = [];
    let originalDates = [];

  const datesContainer = document.getElementById('datesContainer');
  const template = document.getElementById('dateItemTemplate');
  const newDateInput = document.getElementById('newDate');
  const addDateBtn = document.getElementById('addDateBtn');
  const saveDatesBtn = document.getElementById('saveDatesBtn');

    // Initialize Flatpickr for an improved date picking experience
    flatpickr(newDateInput, {
      dateFormat: "Y-m-d",
      allowInput: true,
      minDate: "today" // optional, assuming they don't want to block pasted dates
    });

  // Normalize formatting to YYYY-M-D
  function formatDateString(dStr) {
    const parts = dStr.split('-');
    if (parts.length === 3) {
      return `${parseInt(parts[0])}-${parseInt(parts[1])}-${parseInt(parts[2])}`;
    }
    return dStr;
  }

  function isPastDate(dateStr) {
    const parts = dateStr.split('-');
    if (parts.length === 3) {
      const year = parseInt(parts[0]);
      const month = parseInt(parts[1]) - 1;
      const day = parseInt(parts[2]);
      const dateObj = new Date(year, month, day);
      const now = new Date();
      now.setHours(0,0,0,0);
      return dateObj < now;
    }
    return false;
  }

  function renderDates() {
    datesContainer.innerHTML = '';

    // Check for changes to show/hide save button
    const hasChanges = JSON.stringify(blockedDates.slice().sort()) !== JSON.stringify(originalDates.slice().sort());
    saveDatesBtn.style.display = hasChanges ? 'inline-flex' : 'none';

    // All dates to display: union of blockedDates and originalDates
    const displayDates = [...new Set([...blockedDates, ...originalDates])];

    // Sort dates
    displayDates.sort((a, b) => {
      return new Date(a) - new Date(b);
    });

    let hasPastDates = false;

    displayDates.forEach(dateStr => {
      const clone = template.content.cloneNode(true);
      const li = clone.querySelector('li');
      const span = clone.querySelector('.date-text');
      const btn = clone.querySelector('.remove-btn');

      span.textContent = dateStr;
      
      if (!originalDates.includes(dateStr)) {
        li.classList.add('new-date');
        span.innerHTML = `${dateStr} <span style="color: var(--success-color); font-size: 0.8em; margin-left: 0.5rem; font-weight: 600;">(Unsaved)</span>`;
      } else if (!blockedDates.includes(dateStr)) {
        li.classList.add('deleted-date');
        span.innerHTML = `<del style="opacity: 0.7;">${dateStr}</del> <span style="color: var(--danger-color); font-size: 0.8em; margin-left: 0.5rem; font-weight: 600;">(Removing)</span>`;
        btn.innerHTML = '&#8634;'; // Undo icon
        btn.title = 'Undo removal';
        btn.classList.add('undo-btn');
      }
      
      if (isPastDate(dateStr) && blockedDates.includes(dateStr)) {
        li.classList.add('past');
        span.title = "This date is in the past and will be removed upon saving.";
        hasPastDates = true;
      }

      btn.addEventListener('click', () => {
        if (!blockedDates.includes(dateStr)) {
          // It was deleted, so undo the deletion
          blockedDates.push(dateStr);
        } else {
        // Delete it
          blockedDates = blockedDates.filter(d => d !== dateStr);
        }
        renderDates();
      });

      datesContainer.appendChild(clone);
    });

    if (hasPastDates) {
      if(!document.getElementById('pastDateAlert')) {
         const alertHTML = `<div id="pastDateAlert" class="alert alert-warning" style="margin-top: 1rem;">
          Highlighted dates are in the past. They will be automatically cleared from Shopify when you click Save.
        </div>`;
        datesContainer.insertAdjacentHTML('beforebegin', alertHTML);
      }
    } else {
      const existingAlert = document.getElementById('pastDateAlert');
      if(existingAlert) existingAlert.remove();
    }
  }

  async function fetchDates() {
    try {
      console.log('Fetching /api/dates...');
      const res = await fetch('/api/dates');
      console.log('Response status:', res.status);

      if (!res.ok) {
        const errorText = await res.text();
        console.error('Server responded with error:', res.status, errorText);
        throw new Error(`Failed to load dates: ${res.status}`);
      }
      
      const data = await res.json();
      console.log('Received data from /api/dates:', data);
      blockedDates = data.dates.map(formatDateString);
      originalDates = [...blockedDates];
      renderDates();
    } catch (e) {
      console.error('Error in fetchDates:', e);
      showAlert(e.message);
    }
  }

  addDateBtn.addEventListener('click', () => {
    const val = newDateInput.value;
    if (!val) return;
    
    const formatted = formatDateString(val);
    if (!blockedDates.includes(formatted)) {
      blockedDates.push(formatted);
      renderDates();
    }
    newDateInput.value = '';
  });

  saveDatesBtn.addEventListener('click', async () => {
    saveDatesBtn.textContent = 'Saving...';
    saveDatesBtn.disabled = true;

    try {
      const res = await fetch('/api/dates', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ dates: blockedDates })
      });
      
      if (!res.ok) throw new Error('Failed to save dates');
      const data = await res.json();
      
      blockedDates = data.savedDates; // Server returns cleaned specific dates
      originalDates = [...blockedDates];
      renderDates();
      
      showAlert('Dates successfully synchronized to Shopify.', 'success');
    } catch (e) {
      showAlert(e.message);
    } finally {
      saveDatesBtn.textContent = 'Save to Shopify';
      saveDatesBtn.disabled = false;
    }
  });

  // Load initial dates
  document.addEventListener('DOMContentLoaded', fetchDates);

</script>
