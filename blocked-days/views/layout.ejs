<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blocked Days - Shopify Fulfillment</title>
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#121212">
  <link rel="apple-touch-icon" href="/icons/icon-192x192.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/dark.css">
  <script src="https://unpkg.com/@simplewebauthn/browser/dist/bundle/index.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
</head>
<body>
  
  <header>
    <h1><a href="/" style="color: inherit; text-decoration: none;">Blocked Days</a></h1>
    <nav>
      <% if (locals.user && locals.user.role !=='guest' ) { %>
        <% if (locals.user.role === 'admin') { %>
          <a href="/admin">Admin</a>
        <% } %>
        <a href="/auth/logout">Sign Out</a>
      <% } else if (locals.user && locals.user.role === 'guest') { %>
        <span style="color: var(--text-secondary); margin-left: 1.5rem;">Guest</span>
        <a href="/auth/logout">Sign Out</a>
      <% } %>
    </nav>
  </header>

  <main>
    <%- body %>
  </main>

  <div id="pwa-update-toast" class="update-toast">
    <span>A new version is available!</span>
    <button id="pwa-update-btn" class="btn btn-primary">Update</button>
  </div>

  <div id="notification-modal" class="modal-overlay"
    style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 9999; justify-content: center; align-items: center;">
    <div
      style="background: var(--bg-surface); padding: 2rem; border-radius: var(--radius-md); max-width: 400px; text-align: center;">
      <h2>Enable Notifications</h2>
      <p style="margin-bottom: 1.5rem; color: var(--text-secondary);">We need notification access to provide real-time
        updates for changes to this app. Please click the button below to allow access.</p>
      <button id="allow-notifications-btn" class="btn btn-primary" style="width: 100%;">Allow Notifications</button>
    </div>
  </div>

  <script>
    // Utility for showing alerts
    function showAlert(msg, type = 'error', containerId = 'alerts') {
      const container = document.getElementById(containerId);
      if(!container) return;
      container.innerHTML = `<div class="alert alert-${type}">${msg}</div>`;
      setTimeout(() => { container.innerHTML = ''; }, 5000);
    }

    // Notifications & SSE Logic
    <% if (locals.user) { %>
        document.addEventListener('DOMContentLoaded', () => {
          const notificationModal = document.getElementById('notification-modal');
          const allowBtn = document.getElementById('allow-notifications-btn');

          // Check Notification permissions
          if ('Notification' in window) {
            if (Notification.permission === 'default') {
              notificationModal.style.display = 'flex';
            }

            // Helper to convert VAPID key
            function urlBase64ToUint8Array(base64String) {
              const padding = '='.repeat((4 - base64String.length % 4) % 4);
              const base64 = (base64String + padding)
                .replace(/\-/g, '+')
                .replace(/_/g, '/');
              const rawData = window.atob(base64);
              const outputArray = new Uint8Array(rawData.length);
              for (let i = 0; i < rawData.length; ++i) {
                outputArray[i] = rawData.charCodeAt(i);
              }
              return outputArray;
            }

            // Function to handle push subscription
            async function subscribeToPush() {
              try {
                const reg = await navigator.serviceWorker.ready;
                const vapidRes = await fetch('/api/vapid-key');
                const { publicKey } = await vapidRes.json();

                const subscription = await reg.pushManager.subscribe({
                  userVisibleOnly: true,
                  applicationServerKey: urlBase64ToUint8Array(publicKey)
                });

                await fetch('/api/push-subscribe', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ subscription })
                });
                console.log('Push subscription successful');
              } catch (err) {
                console.error('Failed to subscribe to push:', err);
              }
            }

            allowBtn.addEventListener('click', async () => {
              const permission = await Notification.requestPermission();
              if (permission === 'granted') {
                notificationModal.style.display = 'none';
                await subscribeToPush();
                new Notification('App is ready', { body: 'You will now receive real-time updates.' });
              } else {
                alert('Notifications must be enabled for the app to work correctly.');
              }
            });

            // Automatically subscribe if permission was already granted previously
            if (Notification.permission === 'granted') {
              subscribeToPush();
            }

            // Initialize SSE
            const eventSource = new EventSource('/api/events');

            eventSource.addEventListener('role_changed', (e) => {
              window.location.href = '/auth/refresh';
            });

            eventSource.addEventListener('user_registered', (e) => {
              const data = JSON.parse(e.data);
              if (Notification.permission === 'granted') {
                new Notification('New User Registration', { body: `User ${data.username} has registered.` });
              }
            });

            eventSource.addEventListener('user_logged_in', (e) => {
              const data = JSON.parse(e.data);
              if (Notification.permission === 'granted') {
                new Notification('User Logged In', { body: `User ${data.username} just logged in.` });
              }
            });

            eventSource.addEventListener('dates_updated', (e) => {
              const data = JSON.parse(e.data);
              if (Notification.permission === 'granted') {
                new Notification('Dates Updated', { body: `User ${data.user} updated blocked dates in Shopify.` });
              }
            });

            eventSource.onerror = (err) => {
              console.error("SSE connection error", err);
            };
          }
        });
    <% } %>

  // Service Worker Registration
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/sw.js').then(registration => {
        console.log('ServiceWorker registration successful with scope: ', registration.scope);

        let refreshing;
        navigator.serviceWorker.addEventListener('controllerchange', () => {
          if (refreshing) return;
          window.location.reload();
          refreshing = true;
        });

        function listenForWaitingServiceWorker(reg, callback) {
          function awaitStateChange() {
            reg.installing.addEventListener('statechange', function () {
              if (this.state === 'installed') callback(reg);
            });
          }
          if (!reg) return;
          if (reg.waiting) return callback(reg);
          if (reg.installing) awaitStateChange();
          reg.addEventListener('updatefound', awaitStateChange);
        }

        listenForWaitingServiceWorker(registration, (reg) => {
          const toast = document.getElementById('pwa-update-toast');
          const updateBtn = document.getElementById('pwa-update-btn');

          toast.classList.add('show');

          updateBtn.addEventListener('click', () => {
            reg.waiting.postMessage({ type: 'SKIP_WAITING' });
          });
        });

      }, err => {
        console.log('ServiceWorker registration failed: ', err);
      });
    });
  }
  </script>
</body>
</html>
