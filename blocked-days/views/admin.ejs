<div class="glass-panel" style="max-width: 600px; margin: 2rem auto;">
  <h2>Admin Dashboard</h2>
  <p class="subtitle">System settings and configuration</p>

  <div id="alerts"></div>

  <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--glass-border);">
    <div>
      <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem;">User Registration</h3>
      <p style="color: var(--text-secondary); font-size: 0.9rem;">Allow new users to create accounts and passkeys.</p>
    </div>
    
    <label class="switch">
      <input type="checkbox" id="registrationToggle">
      <span class="slider"></span>
    </label>
  </div>
<div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--glass-border);">
  <h3 style="font-size: 1.2rem; margin-bottom: 1rem;">Users Management</h3>
  <div style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; text-align: left;">
      <thead>
        <tr style="border-bottom: 1px solid var(--glass-border);">
          <th style="padding: 0.5rem;">Username</th>
          <th style="padding: 0.5rem;">Role</th>
          <th style="padding: 0.5rem;">Created</th>
          <th style="padding: 0.5rem; text-align: center;">Actions</th>
        </tr>
      </thead>
      <tbody id="usersTableBody">
        <!-- Users will be populated here -->
      </tbody>
    </table>
  </div>
</div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    const toggle = document.getElementById('registrationToggle');

    // Fetch initial state
    try {
      const res = await fetch('/api/admin/settings');
      if (res.ok) {
        const data = await res.json();
        toggle.checked = data.registration_enabled;
      }
    } catch (e) {
      console.error(e);
      showAlert('Failed to load settings');
    }

    // Handle toggle
    toggle.addEventListener('change', async (e) => {
      const enabled = e.target.checked;
      try {
        const res = await fetch('/api/admin/settings/registration', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ enabled })
        });
        
        if (!res.ok) throw new Error('Failed to update setting');
        const data = await res.json();
        toggle.checked = data.registration_enabled; // confirm state
      } catch (err) {
        console.error(err);
        showAlert(err.message);
        e.target.checked = !enabled; // revert
      }
    });

    // Fetch users
    try {
      const res = await fetch('/api/admin/users');
      if (res.ok) {
        const data = await res.json();
        renderUsers(data.users);
      }
    } catch (e) {
      console.error(e);
      showAlert('Failed to load users');
    }
  });

  function renderUsers(users) {
    const tbody = document.getElementById('usersTableBody');
    tbody.innerHTML = '';

    users.forEach(user => {
      const tr = document.createElement('tr');
      tr.style.borderBottom = '1px solid var(--glass-border)';

      const dateStr = new Date(user.createdAt).toLocaleDateString();

      const roleOptions = ['guest', 'user', 'admin']
        .map(role => `<option value="${role}" ${user.role === role ? 'selected' : ''}>${role}</option>`)
        .join('');

      tr.innerHTML = `
        <td style="padding: 0.5rem;">${user.id}</td>
        <td style="padding: 0.5rem;">
          <select class="role-select" data-user-id="${user.id}" style="padding: 0.25rem; background: var(--glass-bg); color: var(--text-primary); border: 1px solid var(--glass-border); border-radius: 4px;">
            ${roleOptions}
          </select>
        </td>
        <td style="padding: 0.5rem; color: var(--text-secondary);">${dateStr}</td>
        <td style="padding: 0.5rem; text-align: center;">
          <button class="delete-user-btn" data-user-id="${user.id}" style="padding: 0.25rem 0.75rem; background: #e74c3c; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">Delete</button>
        </td>
      `;
      tbody.appendChild(tr);
    });

    // Add event listeners to selects
    document.querySelectorAll('.role-select').forEach(select => {
      select.addEventListener('change', async (e) => {
        const userId = e.target.getAttribute('data-user-id');
        const newRole = e.target.value;
        const oldRole = Array.from(e.target.options).find(opt => opt.defaultSelected).value;

        try {
          const res = await fetch(`/api/admin/users/${userId}/role`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ role: newRole })
          });

          if (!res.ok) {
            const errData = await res.json();
            throw new Error(errData.error || 'Failed to update role');
          }

          // Update default selected
          Array.from(e.target.options).forEach(opt => opt.defaultSelected = opt.value === newRole);
          showAlert(`Role updated successfully for ${userId}`, 'success');
        } catch (err) {
          console.error(err);
          showAlert(err.message, 'error');
          e.target.value = oldRole; // Revert visually
        }
      });
    });

    // Add event listeners to delete buttons
    document.querySelectorAll('.delete-user-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const userId = e.target.getAttribute('data-user-id');
        if (!confirm(`Are you sure you want to delete user ${userId}? This action cannot be undone.`)) {
          return;
        }

        try {
          const res = await fetch(`/api/admin/users/${userId}`, {
            method: 'DELETE'
          });

          if (!res.ok) {
            const errData = await res.json();
            throw new Error(errData.error || 'Failed to delete user');
          }

          showAlert(`User ${userId} deleted successfully`, 'success');
          // Refresh list
          const fetchRes = await fetch('/api/admin/users');
          if (fetchRes.ok) {
            const data = await fetchRes.json();
            renderUsers(data.users);
          }
        } catch (err) {
          console.error(err);
          showAlert(err.message, 'error');
        }
      });
    });
  }
</script>
